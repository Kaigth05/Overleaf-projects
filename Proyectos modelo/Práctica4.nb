          RowBox[{"(", 
           RowBox[{
            RowBox[{"S", "[", "t", "]"}], "+", 
            RowBox[{"i", "[", "t", "]"}], "+", 
            RowBox[{"e", "[", "t", "]"}]}], ")"}]}]}], "\[Minus]", 
        RowBox[{"\[Mu]", " ", "*", 
         RowBox[{"S", "[", "t", "]"}]}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"i", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"r", "*", 
         RowBox[{"i", "[", "t", "]"}], "  ", 
         RowBox[{
          RowBox[{"S", "[", "t", "]"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"S", "[", "t", "]"}], "+", 
            RowBox[{"i", "[", "t", "]"}], "+", 
            RowBox[{"e", "[", "t", "]"}]}], ")"}]}]}], "\[Minus]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"a", "+", "\[Mu]"}], ")"}], 
         RowBox[{"i", "[", "t", "]"}]}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"e", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        RowBox[{"a", "*", 
