Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"r", "=", "0.8"}], ";", 
   RowBox[{"a", "=", "0.8"}], ";", 
   RowBox[{"\[CapitalLambda]", "=", "100"}], ";", 
   RowBox[{"\[Mu]", "=", "0.1"}], ";", 
   RowBox[{"S0", "=", "900000"}], ";", 
   RowBox[{"I0", "=", "100000"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"s", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"S", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"\[CapitalLambda]", "\[Minus]", 
        RowBox[{"r", "*", 
         RowBox[{"i", "[", "t", "]"}], " ", 
